[core]
  editor = nvim
[diff]
  algorithm = histogram
  colorMoved = default
  colorMovedWS = allow-indentation-change
  tool = nvim_difftool
[branch]
  sort = -committerdate
[pull]
  twohead = ort
  ff = only
[rerere]
  enabled = true
[merge]
  conflictStyle = diff3
[mergetool "nvim_difftool"]
  cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"
[gpg]
  format = ssh
[commit]
  gpgsign = true
[alias]
  difft = -c diff.external=difft diff
  showt = -c diff.external=difft show --ext-diff
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
